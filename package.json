{
  "name": "docs-mcpserver",
  "version": "1.0.0",
  "description": "MCP server that exposes Markdown documentation, API reference, and JSON Schema / OpenAPI specs to AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "docs-mcpserver": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "!dist/bundle.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgauffin/markdown-docs-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/jgauffin/markdown-docs-mcp/issues"
  },
  "homepage": "https://github.com/jgauffin/markdown-docs-mcp#readme",
  "scripts": {
    "build": "tsc",
    "bundle": "tsc && esbuild dist/index.js --bundle --platform=node --format=esm --outfile=dist/bundle.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "markdown",
    "documentation",
    "api-reference",
    "openapi",
    "json-schema",
    "model-context-protocol"
  ],
  "author": "jgauffin",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.5.9",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.0.9",
    "esbuild": "^0.27.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
